# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_HOST=mysql
MYSQL_PORT=3306

# Kafka
KAFKA_BROKER=kafka:9092

# Kong
CONTROL_PLANE_ID=<your-control-plane-id>
EVENT_GATEWAY_CP_ID=<your-event-gateway-cp-id>
DECK_KONNECT_CONTROL_PLANE_NAME=<your-control-plane-name>
DECK_OPENAI_API_KEY=<your-openai-api-key>
# Kong openid-connect プラグインが参照する Keycloak discovery エンドポイント
DECK_KEYCLOAK_ISSUER=http://keycloak:8081/realms/jungle-store/.well-known/openid-configuration

# Keycloak (end-user SSO IdP)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=jungle-store
# ブラウザが到達するフロントチャネル URL（iss / 認可エンドポイント）。/etc/hosts は不要。
KEYCLOAK_PUBLIC_URL=http://localhost:8081
# コンテナが到達するバックチャネル URL（discovery / token / jwks の取得先。Docker DNS）
KEYCLOAK_INTERNAL_URL=http://keycloak:8081

# NextAuth (Auth.js) — AUTH_SECRET は `openssl rand -base64 32` で生成
AUTH_SECRET=<your-auth-secret>
AUTH_URL=http://localhost:3000
AUTH_KEYCLOAK_ID=jungle-store-frontend
AUTH_KEYCLOAK_SECRET=<your-keycloak-client-secret>

# Service URLs (for inter-service communication)
CATALOG_SERVICE_URL=http://catalog-service:3001
CART_SERVICE_URL=http://cart-service:3002
ORDER_SERVICE_URL=http://order-service:3003
SHIPPING_SERVICE_URL=http://shipping-service:3004
USER_SERVICE_URL=http://user-service:3005
AGENT_SERVICE_URL=http://agent-service:3006

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# ナビの Grafana リンク先（otel-lgtm の Grafana UI）
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3010
